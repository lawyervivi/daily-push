  {cat:'fa', title:'✈️ 两高发文惩治"机闹"维护民航安全', content:'最高法、最高检联合发布关于办理危害民航飞行安全刑事案件适用法律若干问题的解释，填补了危害民航飞行安全刑事案件法律适用的细化空白，明确了罪与非罪的边界，自2026年4月9日起施行。', source:'法治瞭望', link:'https://www.fzbdw.org.cn/news/'},
  {cat:'fa', title:'💸 高利贷入刑！2026新规重拳出击', content:'2026年国家金融监管总局等多部门联合发力，非法高利放贷正式入刑。无资质放贷、以营利为目的高频向陌生人放款、利率超36%均将面临刑事追责。新规还严禁暴力催收，22:00-8:00严禁催收，违者直接处罚。', source:'今日头条', link:'http://m.toutiao.com/group/7628100380789883426/'}
];

let currentIndex = 0;
let filteredNews = [...newsData];

function renderCards() {
  const container = document.getElementById('cards');
  container.innerHTML = '';
  filteredNews.forEach((news, i) => {
    const card = document.createElement('div');
    card.className = `card ${i === currentIndex ? 'show' : ''}`;
    card.innerHTML = `
      <span class="card-category ${news.cat}">${news.cat === 'cai' ? '📈 财经' : news.cat === 'zheng' ? '🌐 政闻' : '⚖️ 法制'}</span>
      <h2>${news.title}</h2>
      <div class="card-content"><p>${news.content}</p></div>
      <div class="card-footer">
        <span class="source">📰 来源：${news.source}</span>
        <a href="${news.link}" target="_blank" class="link-btn">阅读原文 →</a>
      </div>
    `;
    container.appendChild(card);
  });
  updatePagination();
}

function updatePagination() {
  document.getElementById('pageInfo').textContent = `${currentIndex + 1} / ${filteredNews.length}`;
  document.getElementById('prevBtn').disabled = currentIndex === 0;
  document.getElementById('nextBtn').disabled = currentIndex === filteredNews.length - 1;
  document.querySelectorAll('.card').forEach((c, i) => c.classList.toggle('show', i === currentIndex));
}

function nextCard() {
  if (currentIndex < filteredNews.length - 1) { currentIndex++; renderCards(); }
}
function prevCard() {
  if (currentIndex > 0) { currentIndex--; renderCards(); }
}

function filterNews(type) {
  document.querySelectorAll('.nav button').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  filteredNews = type === 'all' ? [...newsData] : newsData.filter(n => n.cat === type);
  currentIndex = 0;
  renderCards();
}

document.addEventListener('keydown', e => {
  if (e.key === 'ArrowRight' || e.key === 'ArrowDown') nextCard();
  if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') prevCard();
});

renderCards();
</script>
</body>
</html>
